<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.homefragment.HomeFragment"
    android:background="@color/bgc">
   <androidx.constraintlayout.widget.ConstraintLayout
       android:layout_width="match_parent"
       android:layout_height="match_parent">
       <com.google.android.material.appbar.MaterialToolbar
           android:id="@+id/toolbar"
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           app:title="Career Shiksha"
           app:titleCentered="true"
           app:titleTextColor="@color/black"
           app:layout_constraintTop_toTopOf="parent"
           app:layout_constraintStart_toStartOf="parent"
           app:layout_constraintEnd_toEndOf="parent"
           android:background="@color/white"/>
       <TextView
           android:id="@+id/tv_title"
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:text="What Would you like to learn today?"
           android:textStyle="bold"
           android:textSize="30sp"
           app:layout_constraintTop_toBottomOf="@+id/toolbar"
           android:layout_margin="20dp"
           android:textColor="@color/black"/>
       <com.google.android.material.card.MaterialCardView
           android:id="@+id/mc_card1"
           android:layout_width="170dp"
           android:layout_height="170dp"
           app:cardCornerRadius="12dp"
           app:layout_constraintTop_toBottomOf="@+id/tv_title"
           app:layout_constraintStart_toStartOf="parent"
           android:layout_margin="15dp"
           android:backgroundTint="@color/cart1">
           <ImageView
               android:layout_width="match_parent"
               android:layout_height="100dp"
               android:src="@drawable/devloping"
               android:paddingTop="15dp"
               android:layout_gravity="center|top"/>
           <TextView
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:text="Devloping"
               android:textColor="@color/white"
               android:textSize="30sp"
               android:textStyle="bold"
               android:layout_gravity="bottom"
               android:paddingBottom="40dp"
               android:gravity="center"/>

       </com.google.android.material.card.MaterialCardView>
       <com.google.android.material.card.MaterialCardView
           android:id="@+id/cv_card2"
           android:layout_width="170dp"
           android:layout_height="170dp"
           app:cardCornerRadius="12dp"
           app:layout_constraintTop_toBottomOf="@+id/tv_title"
           app:layout_constraintStart_toEndOf="@+id/mc_card1"
           app:layout_constraintEnd_toEndOf="parent"
           android:layout_margin="15dp"
           android:backgroundTint="@color/cart2">
           <ImageView
               android:layout_width="100dp"
               android:layout_height="100dp"
               android:paddingTop="15dp"
               android:src="@drawable/desiging"
               android:layout_gravity="center|top"/>
           <TextView
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:text="Designing"
               android:textColor="@color/white"
               android:textSize="30sp"
               android:textStyle="bold"
               android:layout_gravity="bottom"
               android:paddingBottom="40dp"
               android:gravity="center"/>

       </com.google.android.material.card.MaterialCardView>
       <com.google.android.material.card.MaterialCardView
           android:id="@+id/mc_card3"
           android:layout_width="170dp"
           android:layout_height="170dp"
           app:cardCornerRadius="12dp"
           app:layout_constraintTop_toBottomOf="@+id/mc_card1"
           app:layout_constraintStart_toStartOf="parent"
           android:layout_margin="15dp"
           android:backgroundTint="@color/cart3">
           <ImageView
               android:layout_width="match_parent"
               android:layout_height="100dp"
               android:src="@drawable/ai"
               android:paddingTop="15dp"
               android:layout_gravity="center|top"/>
           <TextView
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:text="Ai and Ml"
               android:textColor="@color/white"
               android:textSize="30sp"
               android:textStyle="bold"
               android:layout_gravity="bottom"
               android:paddingBottom="40dp"
               android:gravity="center"/>

       </com.google.android.material.card.MaterialCardView>
       <com.google.android.material.card.MaterialCardView
           android:id="@+id/cv_card4"
           android:layout_width="170dp"
           android:layout_height="170dp"
           app:cardCornerRadius="12dp"
           app:layout_constraintTop_toBottomOf="@+id/cv_card2"
           app:layout_constraintStart_toEndOf="@+id/mc_card3"
           app:layout_constraintEnd_toEndOf="parent"
           android:layout_margin="15dp"
           android:backgroundTint="@color/cart4">
           <ImageView
               android:layout_width="100dp"
               android:layout_height="100dp"
               android:paddingTop="15dp"
               android:src="@drawable/explore"
               android:layout_gravity="center|top"/>
           <TextView
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:text="Explore"
               android:textColor="@color/white"
               android:textSize="30sp"
               android:textStyle="bold"
               android:layout_gravity="bottom"
               android:paddingBottom="40dp"
               android:gravity="center"/>

       </com.google.android.material.card.MaterialCardView>
       <TextView
           android:id="@+id/tv_popular_courses"
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:text="Popular Courses"
           android:textStyle="bold"
           android:textSize="20sp"
           app:layout_constraintTop_toBottomOf="@+id/mc_card3"
           android:layout_marginStart="20dp"
           android:layout_marginTop="20dp"
           android:textColor="@color/black"/>
       <TextView
           android:id="@+id/tv_seemore"
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:text="See all"
           android:textSize="18sp"
           android:textStyle="bold"
           app:layout_constraintTop_toBottomOf="@+id/mc_card3"
           android:gravity="end"
           android:layout_marginTop="20dp"
           android:layout_marginEnd="20dp"/>
       <androidx.recyclerview.widget.RecyclerView
           android:id="@+id/recycler_view"
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           app:layout_constraintTop_toBottomOf="@+id/tv_popular_courses"/>
   </androidx.constraintlayout.widget.ConstraintLayout>



</androidx.core.widget.NestedScrollView>